-- Slider
local function CreateSlider(parent, text, y, min, max, default, callback)
	local container = Instance.new("Frame", parent)
	container.Size = UDim2.new(0.9,0,0,55)
	container.Position = UDim2.fromOffset(15,y)
	container.BackgroundColor3 = Color3.fromRGB(35,35,35)
	Instance.new("UICorner", container).CornerRadius = UDim.new(0,8)
	container.ZIndex = 5

	local label = Instance.new("TextLabel", container)
	label.Size = UDim2.new(1,-20,0,22)
	label.Position = UDim2.fromOffset(10,6)
	label.BackgroundTransparency = 1
	label.Text = text .. ": " .. default
	label.TextColor3 = Color3.new(1,1,1)
	label.Font = Enum.Font.GothamSemibold
	label.TextSize = 12
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.ZIndex = 6

	local track = Instance.new("Frame", container)
	track.Position = UDim2.fromOffset(12,32)
	track.Size = UDim2.new(1,-24,0,8)
	track.BackgroundColor3 = Color3.fromRGB(60,60,60)
	Instance.new("UICorner", track).CornerRadius = UDim.new(0,4)
	track.ZIndex = 6

	local fill = Instance.new("Frame", track)
	fill.BackgroundColor3 = Color3.fromRGB(220,40,40)
	fill.Size = UDim2.fromScale((default-min)/(max-min),1)
	fill.BorderSizePixel = 0
	Instance.new("UICorner", fill).CornerRadius = UDim.new(0,4)
	fill.ZIndex = 7

	local thumb = Instance.new("Frame", track)
	thumb.Size = UDim2.fromOffset(16,16)
	thumb.Position = UDim2.new((default-min)/(max-min), -8, 0.5, -8)
	thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
	thumb.BorderSizePixel = 0
	Instance.new("UICorner", thumb).CornerRadius = UDim.new(1,0)
	thumb.ZIndex = 8

	local dragging = false

	local function Update(x)
		local clamped = math.clamp(x, 0, 1)
		fill.Size = UDim2.fromScale(clamped, 1)
		thumb.Position = UDim2.new(clamped, -8, 0.5, -8)
		local value = math.floor(min + (max - min) * clamped)
		label.Text = text .. ": " .. value
		callback(value)
	end

	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			Panel.Draggable = false
			Update((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
		end
	end)

	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			Update((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X)
		end
	end)

	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
			Panel.Draggable = true
		end
	end)
end

