-- Funções de lógica (mantidas iguais)
local function IsEnemy(plr)
	if plr == Player then return false end
	if not State.TeamCheck then return true end
	if not Player.Team or not plr.Team then return true end
	return plr.Team ~= Player.Team
end

local function GetAimbotPart(char)
	if not char then return nil end
	if State.AimbotPart == "Cabeça" then return char:FindFirstChild("Head") end
	return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
end

local function ClearVision(part, char)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist
	params.FilterDescendantsInstances = {Player.Character, Camera}
	local direction = (part.Position - Camera.CFrame.Position)
	local ray = workspace:Raycast(Camera.CFrame.Position, direction.Unit * direction.Magnitude, params)
	return not ray or ray.Instance:IsDescendantOf(char)
end

local function GetTarget()
	local closest, dist, center = nil, State.FOVSize, Camera.ViewportSize/2
	for _, plr in Players:GetPlayers() do
		if plr ~= Player and plr.Character and IsEnemy(plr) then
			local part = GetAimbotPart(plr.Character)
			if part then
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
					if onScreen then
						local mag = (Vector2.new(pos.X, pos.Y) - center).Magnitude
						if mag < dist and (not State.WallCheck or ClearVision(part, plr.Character)) then
							dist = mag
							closest = part
						end
					end
				end
			end
		end
	end
	return closest
end

-- ESP System (com tracer saindo do topo)
local ESP = {}
local FIXED_BOX_WIDTH, FIXED_BOX_HEIGHT, FIXED_BAR_WIDTH = 35, 55, 3

local function NewESP(plr)
	if plr == Player then return end
	local box = Drawing.new("Square"); box.Thickness = 1; box.Filled = false; box.Visible = false
	local healthBarBg = Drawing.new("Square"); healthBarBg.Thickness = 1; healthBarBg.Filled = true; healthBarBg.Color = Color3.fromRGB(0,0,0); healthBarBg.Visible = false
	local healthBarFill = Drawing.new("Square"); healthBarFill.Thickness = 1; healthBarFill.Filled = true; healthBarFill.Visible = false
	local skeletonLines = {}
	for i = 1, 15 do 
		local line = Drawing.new("Line")
		line.Thickness = 1.5; line.Color = Color3.fromRGB(255,0,0); line.Visible = false
		table.insert(skeletonLines, line)
	end
	local name = Drawing.new("Text"); name.Center = true; name.Outline = true; name.Size = 12; name.Color = Color3.new(1,1,1); name.Visible = false
	local dist = Drawing.new("Text"); dist.Center = true; dist.Outline = true; dist.Size = 10; dist.Color = Color3.new(1,1,1); dist.Visible = false
	local tracer = Drawing.new("Line"); tracer.Thickness = 1; tracer.Color = Color3.fromRGB(255,0,0); tracer.Visible = false
	ESP[plr] = {box=box, healthBarBg=healthBarBg, healthBarFill=healthBarFill, skeleton=skeletonLines, name=name, dist=dist, tracer=tracer}
end

for _, p in pairs(Players:GetPlayers()) do NewESP(p) end
Players.PlayerAdded:Connect(NewESP)
Players.PlayerRemoving:Connect(function(plr)
	if ESP[plr] then
		for _, v in pairs(ESP[plr]) do
			if typeof(v) == "table" then for _, l in pairs(v) do l:Remove() end else v:Remove() end
		end
		ESP[plr] = nil
	end
end)

local function UpdateESP()
	for plr, obj in pairs(ESP) do
		local char = plr.Character
		if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Head") and char:FindFirstChildOfClass("Humanoid") then
			local hrp, head, hum = char.HumanoidRootPart, char.Head, char:FindFirstChildOfClass("Humanoid")
			local pos, vis = Camera:WorldToViewportPoint(hrp.Position)
			if vis then
				local distance, cx, cy = (hrp.Position-Camera.CFrame.Position).Magnitude, pos.X, pos.Y
				local bw, bh = FIXED_BOX_WIDTH, FIXED_BOX_HEIGHT
				local bPos = Vector2.new(cx-bw/2, cy-bh/2)
				local isEnemy = IsEnemy(plr)

				if State.ESP_Box then
					obj.box.Size = Vector2.new(bw,bh)
					obj.box.Position = bPos
					obj.box.Color = isEnemy and Color3.fromRGB(255,0,0) or Color3.fromRGB(100,200,255)
					obj.box.Visible = true
				else
					obj.box.Visible = false
				end

				if State.ESP_Box and isEnemy then
					obj.dist.Text = math.floor(distance).."m"
					obj.dist.Position = Vector2.new(cx, bPos.Y+bh+4)
					obj.dist.Visible = true
				else
					obj.dist.Visible = false
				end

				if State.ESP_Health and isEnemy then
					local hp = math.clamp(hum.Health/hum.MaxHealth,0,1)
					local bh2 = bh-2
					obj.healthBarBg.Size = Vector2.new(FIXED_BAR_WIDTH,bh2)
					obj.healthBarBg.Position = Vector2.new(bPos.X-6,bPos.Y+1)
					obj.healthBarBg.Visible = true
					obj.healthBarFill.Size = Vector2.new(FIXED_BAR_WIDTH-1,(bh2-1)*hp)
					obj.healthBarFill.Position = Vector2.new(bPos.X-5.5,bPos.Y+1+(bh2-1)*(1-hp)+0.5)
					obj.healthBarFill.Color = hp > 0.6 and Color3.fromRGB(0,255,0) or (hp > 0.3 and Color3.fromRGB(255,255,0) or Color3.fromRGB(255,0,0))
					obj.healthBarFill.Visible = true
				else
					obj.healthBarBg.Visible = false
					obj.healthBarFill.Visible = false
				end

				if State.ESP_Skeleton and isEnemy then
					local function gp(part, off)
						if char:FindFirstChild(part) then
							local p = char[part].Position + (off or Vector3.new(0,0,0))
							local sp, v = Camera:WorldToViewportPoint(p)
							if v then return Vector2.new(sp.X,sp.Y) end
						end
						return nil
					end

					local headP = gp("Head")
					local neckP = gp("Head", Vector3.new(0,-0.3,0))
					local torsoP = gp("UpperTorso") or gp("Torso")
					local pelvisP = gp("LowerTorso") or gp("Torso", Vector3.new(0,-0.8,0))

					local lShoulder = gp("LeftUpperArm") or gp("Left Arm", Vector3.new(0,0.3,0))
					local lElbow = gp("LeftLowerArm") or gp("Left Arm")
					local lHand = gp("LeftHand") or gp("Left Arm", Vector3.new(0,-0.3,0))

					local rShoulder = gp("RightUpperArm") or gp("Right Arm", Vector3.new(0,0.3,0))
					local rElbow = gp("RightLowerArm") or gp("Right Arm")
					local rHand = gp("RightHand") or gp("Right Arm", Vector3.new(0,-0.3,0))

					local lHip = gp("LeftUpperLeg") or gp("Left Leg", Vector3.new(0,0.3,0))
					local lKnee = gp("LeftLowerLeg") or gp("Left Leg")
					local lFoot = gp("LeftFoot") or gp("Left Leg", Vector3.new(0,-0.3,0))

					local rHip = gp("RightUpperLeg") or gp("Right Leg", Vector3.new(0,0.3,0))
					local rKnee = gp("RightLowerLeg") or gp("Right Leg")
					local rFoot = gp("RightFoot") or gp("Right Leg", Vector3.new(0,-0.3,0))

					local lines = {
						{headP, neckP}, {neckP, torsoP}, {torsoP, pelvisP},
						{neckP, lShoulder}, {lShoulder, lElbow}, {lElbow, lHand},
						{neckP, rShoulder}, {rShoulder, rElbow}, {rElbow, rHand},
						{pelvisP, lHip}, {lHip, lKnee}, {lKnee, lFoot},
						{pelvisP, rHip}, {rHip, rKnee}, {rKnee, rFoot}
					}

					for i=1,15 do
						local c = lines[i]
						if c and c[1] and c[2] then 
							obj.skeleton[i].From = c[1]
							obj.skeleton[i].To = c[2]
							obj.skeleton[i].Visible = true 
						else
							obj.skeleton[i].Visible = false 
						end
					end
				else
					for _, l in ipairs(obj.skeleton) do l.Visible = false end
				end

				if State.ESP_Name and isEnemy then
					obj.name.Text = plr.Name
					obj.name.Position = Vector2.new(cx,bPos.Y-12)
					obj.name.Visible = true
				else
					obj.name.Visible = false
				end

				if State.Tracer and isEnemy then
					obj.tracer.From = Vector2.new(Camera.ViewportSize.X/2, 0)  -- topo da tela
					obj.tracer.To = Vector2.new(cx, bPos.Y + bh/2)
					obj.tracer.Visible = true
				else
					obj.tracer.Visible = false
				end
			else
				for k, v in pairs(obj) do 
					if k == "skeleton" then 
						for _, l in ipairs(v) do l.Visible = false end 
					else 
						v.Visible = false 
					end 
				end
			end
		else
			for k, v in pairs(obj) do 
				if k == "skeleton" then 
					for _, l in ipairs(v) do l.Visible = false end 
				else 
					v.Visible = false 
				end 
			end
		end
	end
end

