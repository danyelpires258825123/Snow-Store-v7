-- Copiar link com feedback
DiscordBtn.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		if setclipboard then
			setclipboard(DISCORD_LINK)
			
			local originalText = DiscordBtn.Text
			DiscordBtn.Text = "Link Copiado! ✓"
			DiscordBtn.BackgroundColor3 = Color3.fromRGB(70, 180, 70) -- verde sucesso
			
			task.delay(2.2, function()
				DiscordBtn.Text = originalText
				DiscordBtn.BackgroundColor3 = Color3.fromRGB(114, 137, 218)
			end)
		end
	end
end)

-- Tab Switch
local function ShowPage(page)
	AimbotPage.Visible = page == AimbotPage
	VisualPage.Visible = page == VisualPage
	DiscordPage.Visible = page == DiscordPage
end

TabAimbot.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then ShowPage(AimbotPage) end
end)

TabVisual.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then ShowPage(VisualPage) end
end)

TabDiscord.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then ShowPage(DiscordPage) end
end)

ToggleButton.InputBegan:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
		Panel.Visible = not Panel.Visible
	end
end)
